<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CJ Training Tracker</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;800;900&family=Karla:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0e0f0d;--surface:#161814;--surface2:#1e2019;--surface3:#252820;
  --border:#2a2d24;--border2:#333628;
  --green:#6dbb5a;--green-dim:#3d6e2e;--green-pale:rgba(109,187,90,0.08);
  --amber:#d4962a;--amber-pale:rgba(212,150,42,0.10);
  --blue:#5b8fd4;--blue-pale:rgba(91,143,212,0.10);
  --red:#d45b5b;--red-pale:rgba(212,91,91,0.10);
  --purple:#9b7dd4;--purple-pale:rgba(155,125,212,0.10);
  --teal:#4ab8a8;--teal-pale:rgba(74,184,168,0.10);
  --slate:#606870;--slate-pale:rgba(96,104,112,0.15);
  --text:#dde0cc;--text-mid:#7a7e6a;--text-dim:#3a3d2e;--white:#ecefd8;
}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;}
body{background:var(--bg);font-family:'Karla',sans-serif;color:var(--text);display:flex;flex-direction:column;font-size:14px;}

/* ── TOPBAR ── */
.topbar{display:flex;align-items:center;justify-content:space-between;padding:0 20px;height:50px;background:var(–surface);border-bottom:1px solid var(–border);flex-shrink:0;gap:10px;}
.logo{font-family:‘Barlow Condensed’,sans-serif;font-size:1.15rem;font-weight:900;letter-spacing:2px;text-transform:uppercase;color:var(–white);white-space:nowrap;}
.logo em{color:var(–green);font-style:normal;}
.nav-tabs{display:flex;gap:2px;overflow-x:auto;}
.nav-tab{padding:5px 12px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:1.2px;text-transform:uppercase;background:transparent;border:1px solid transparent;border-radius:5px;color:var(–text-mid);cursor:pointer;transition:all .15s;white-space:nowrap;flex-shrink:0;}
.nav-tab.active{background:var(–surface2);border-color:var(–border2);color:var(–green);}
.deadline-pill{font-family:‘Barlow Condensed’,sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:1px;background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:4px 10px;color:var(–text-dim);white-space:nowrap;}
.deadline-pill span{color:var(–amber);}

/* ── LAYOUT ── */
.main{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.view{display:none;flex:1;min-height:0;flex-direction:column;}
.view.active{display:flex;}
.scroll{flex:1;min-height:0;overflow-y:auto;padding:14px 20px 32px;}
.scroll::-webkit-scrollbar{width:4px;}
.scroll::-webkit-scrollbar-thumb{background:var(–border2);}

/* ── WEEK NAV ── */
.week-nav{display:flex;align-items:center;justify-content:space-between;padding:10px 20px;background:var(–surface);border-bottom:1px solid var(–border);flex-shrink:0;gap:10px;flex-wrap:wrap;}
.wnav-btn{background:var(–surface2);border:1px solid var(–border2);color:var(–text-mid);padding:5px 12px;border-radius:5px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .15s;}
.week-title{font-family:‘Barlow Condensed’,sans-serif;font-size:0.95rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(–white);text-align:center;}
.week-sub{font-size:0.62rem;text-align:center;color:var(–text-mid);margin-top:1px;}
.prog-bar{height:2px;background:var(–border);flex-shrink:0;}
.prog-fill{height:100%;background:var(–green);transition:width .3s;}

/* ── WEEK TYPE SELECTOR ── */
.week-type-row{display:flex;align-items:center;gap:8px;padding:8px 20px;background:var(–surface2);border-bottom:1px solid var(–border);flex-shrink:0;flex-wrap:wrap;}
.wt-label{font-size:0.65rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(–text-mid);}
.wt-btn{padding:4px 12px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.7rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;background:transparent;border:1px solid var(–border2);border-radius:4px;color:var(–text-dim);cursor:pointer;transition:all .15s;}
.wt-btn.active{border-color:var(–green-dim);color:var(–green);background:var(–green-pale);}
.wt-btn.amber{border-color:rgba(212,150,42,0.4);}
.wt-btn.amber.active{border-color:var(–amber);color:var(–amber);background:var(–amber-pale);}
.wt-btn.blue{border-color:rgba(91,143,212,0.3);}
.wt-btn.blue.active{border-color:var(–blue);color:var(–blue);background:var(–blue-pale);}

/* ── DAY SECTION ── */
.day-section{margin-bottom:8px;}
.day-hdr{display:flex;align-items:center;gap:8px;margin-bottom:5px;}
.day-lbl{font-family:‘Barlow Condensed’,sans-serif;font-size:0.88rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(–white);}
.day-line{flex:1;height:1px;background:var(–border);}
.day-done-badge{font-family:‘Barlow Condensed’,sans-serif;font-size:0.58rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(–green);background:var(–green-pale);border:1px solid var(–green-dim);padding:2px 7px;border-radius:3px;}

/* ── SESSION CARD ── */
.scard{background:var(–surface);border:1px solid var(–border);border-radius:9px;margin-bottom:6px;overflow:hidden;transition:border-color .15s;}
.scard.done{border-color:var(–green-dim);}
.scard.skipped{opacity:0.38;}
.scard-top{display:flex;align-items:center;gap:8px;padding:9px 12px;}
.check-btn{width:20px;height:20px;border-radius:4px;border:2px solid var(–border2);background:transparent;flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .15s;}
.check-btn.done{background:var(–green);border-color:var(–green);}
.check-btn.done::after{content:‘✓’;font-size:11px;color:#0e0f0d;font-weight:800;}
.type-dot{width:7px;height:7px;border-radius:2px;flex-shrink:0;}
.scard-info{flex:1;min-width:0;}
.scard-title{font-size:0.78rem;font-weight:600;color:var(–text);line-height:1.2;}
.scard-time{font-size:0.63rem;color:var(–text-mid);margin-top:1px;font-family:‘Barlow Condensed’,sans-serif;letter-spacing:0.4px;}
.star-row{display:flex;gap:2px;flex-shrink:0;}
.star{font-size:13px;cursor:pointer;color:var(–text-dim);transition:color .1s;line-height:1;}
.star.lit{color:var(–amber);}
.expand-btn{background:none;border:none;color:var(–text-dim);cursor:pointer;font-size:11px;padding:2px 4px;transition:transform .15s;flex-shrink:0;}
.expand-btn.open{transform:rotate(180deg);}

/* ── EDIT PENCIL ── */
.edit-pencil{background:none;border:none;color:var(–text-dim);cursor:pointer;font-size:11px;padding:2px 5px;border-radius:4px;transition:color .15s;flex-shrink:0;}
.edit-pencil:hover{color:var(–amber);}

/* ── SESSION DETAIL ── */
.scard-detail{display:none;padding:0 12px 12px;border-top:1px solid var(–border);}
.scard-detail.open{display:block;}
.det-label{font-size:0.62rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(–text-mid);margin:9px 0 4px;}
.notes-ta{width:100%;background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:7px 9px;font-family:‘Karla’,sans-serif;font-size:0.74rem;color:var(–text);resize:vertical;min-height:52px;outline:none;transition:border-color .15s;}
.notes-ta:focus{border-color:var(–green-dim);}
.notes-ta::placeholder{color:var(–text-dim);}

/* ── MUSCLE GROUPS ── */
.muscle-grid{display:flex;flex-wrap:wrap;gap:5px;margin-top:4px;}
.mg-check{display:flex;align-items:center;gap:5px;background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:4px 8px;cursor:pointer;transition:all .15s;user-select:none;}
.mg-check.checked{background:var(–blue-pale);border-color:var(–blue);}
.mg-check input{display:none;}
.mg-label{font-size:0.68rem;font-weight:600;color:var(–text-mid);}
.mg-check.checked .mg-label{color:var(–blue);}

/* ── SKIP BTN ── */
.skip-btn{margin-top:7px;background:transparent;border:1px solid var(–border2);color:var(–text-dim);padding:3px 9px;border-radius:4px;font-size:0.65rem;font-family:‘Barlow Condensed’,sans-serif;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:all .15s;}
.skip-btn:hover{border-color:var(–red);color:var(–red);}
.skip-btn.active{background:var(–red-pale);border-color:var(–red);color:var(–red);}

/* ── LOG ROUND BTN ── */
.log-round-btn{width:100%;margin-bottom:7px;background:var(–purple-pale);border:1px dashed var(–purple);color:var(–purple);padding:9px;border-radius:9px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.78rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;cursor:pointer;transition:all .15s;}
.log-round-btn:hover{background:rgba(155,125,212,0.15);}

/* ── MODAL ── */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,0.78);z-index:200;display:flex;align-items:center;justify-content:center;padding:14px;}
.overlay.hidden{display:none;}
.modal{background:var(–surface);border:1px solid var(–border2);border-radius:12px;width:100%;max-width:530px;max-height:92vh;overflow-y:auto;display:flex;flex-direction:column;}
.modal::-webkit-scrollbar{width:4px;}
.modal::-webkit-scrollbar-thumb{background:var(–border2);}
.modal-hdr{padding:16px 18px 12px;border-bottom:1px solid var(–border);display:flex;align-items:center;justify-content:space-between;flex-shrink:0;}
.modal-ttl{font-family:‘Barlow Condensed’,sans-serif;font-size:1.05rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;color:var(–white);}
.modal-close{background:none;border:none;color:var(–text-mid);font-size:1.2rem;cursor:pointer;padding:2px 6px;line-height:1;}
.modal-body{padding:14px 18px 18px;}
.form-row{display:flex;gap:9px;margin-bottom:9px;flex-wrap:wrap;}
.fgrp{flex:1;min-width:110px;}
.flabel{font-size:0.62rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:var(–text-mid);margin-bottom:3px;display:block;}
.finput{width:100%;background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:6px 9px;font-family:‘Karla’,sans-serif;font-size:0.78rem;color:var(–text);outline:none;transition:border-color .15s;}
.finput:focus{border-color:var(–green-dim);}

/* ── SCORECARD ── */
.sc-grid{display:grid;gap:3px;margin:8px 0;}
.sc-cell{background:var(–surface2);border:1px solid var(–border);border-radius:3px;padding:3px 2px;text-align:center;}
.sc-cell.hdr{background:var(–surface3);font-family:‘Barlow Condensed’,sans-serif;font-size:0.6rem;font-weight:700;letter-spacing:0.5px;text-transform:uppercase;color:var(–text-mid);}
.sc-cell.total-cell{background:var(–surface3);}
.sc-hole-inp{width:100%;background:transparent;border:none;outline:none;font-family:‘Karla’,sans-serif;font-size:0.76rem;color:var(–text);text-align:center;}
.sc-hole-inp::placeholder{color:var(–text-dim);}
.sc-par-val{font-size:0.6rem;color:var(–text-mid);font-family:‘Barlow Condensed’,sans-serif;}
.sc-totals{display:flex;gap:8px;margin-top:6px;flex-wrap:wrap;}
.sc-tot{background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:5px 10px;text-align:center;flex:1;min-width:72px;}
.sc-tot-lbl{font-size:0.58rem;text-transform:uppercase;letter-spacing:1px;color:var(–text-mid);font-weight:600;}
.sc-tot-val{font-family:‘Barlow Condensed’,sans-serif;font-size:1.25rem;font-weight:800;color:var(–white);line-height:1.1;}
.sc-tot-val.gv{color:var(–green);}
.sc-tot-val.rv{color:var(–red);}
.save-btn{width:100%;margin-top:12px;background:var(–green);border:none;color:#0e0f0d;padding:10px;border-radius:7px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.88rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:opacity .15s;}
.save-btn:hover{opacity:0.87;}

/* ── EDIT SESSION MODAL ── */
.edit-modal .modal{max-width:420px;}

/* ── ROUNDS LIST ── */
.rounds-toolbar{padding:10px 20px;border-bottom:1px solid var(–border);flex-shrink:0;display:flex;align-items:center;justify-content:space-between;}
.round-entry{background:var(–surface);border:1px solid var(–border);border-radius:8px;padding:9px 12px;margin-bottom:6px;display:flex;align-items:center;justify-content:space-between;gap:10px;cursor:pointer;transition:border-color .15s;}
.round-entry:hover{border-color:var(–border2);}
.re-title{font-size:0.78rem;font-weight:600;color:var(–text);}
.re-sub{font-size:0.65rem;color:var(–text-mid);margin-top:2px;}
.re-score{font-family:‘Barlow Condensed’,sans-serif;font-size:1.55rem;font-weight:800;color:var(–white);line-height:1;}
.re-par{font-size:0.63rem;font-weight:600;text-align:right;}
.re-par.pos{color:var(–red);}
.re-par.neg{color:var(–green);}
.re-par.even{color:var(–text-mid);}
.del-btn{background:none;border:none;color:var(–text-dim);cursor:pointer;font-size:0.85rem;padding:4px;border-radius:4px;opacity:0;transition:opacity .15s;}
.round-entry:hover .del-btn{opacity:1;}

/* ── DASHBOARD ── */
.kpi-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:7px;margin-bottom:14px;}
.kpi{background:var(–surface);border:1px solid var(–border);border-radius:9px;padding:12px 14px;}
.kpi-lbl{font-size:0.6rem;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(–text-mid);margin-bottom:3px;}
.kpi-val{font-family:‘Barlow Condensed’,sans-serif;font-size:1.9rem;font-weight:900;color:var(–white);line-height:1;}
.kpi-val.gv{color:var(–green);}
.kpi-val.av{color:var(–amber);}
.kpi-sub{font-size:0.62rem;color:var(–text-dim);margin-top:2px;}
.dash-sec{font-family:‘Barlow Condensed’,sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(–text-dim);margin:12px 0 7px;}
.chart-box{background:var(–surface);border:1px solid var(–border);border-radius:9px;padding:14px;margin-bottom:9px;}
.chart-ttl{font-family:‘Barlow Condensed’,sans-serif;font-size:0.68rem;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;color:var(–text-mid);margin-bottom:10px;}
.chart-wrap{position:relative;height:140px;width:100%;}
canvas{display:block;}
.hcp-row{display:flex;align-items:center;gap:8px;margin-bottom:9px;flex-wrap:wrap;}
.hcp-row input{background:var(–surface2);border:1px solid var(–border2);border-radius:5px;padding:5px 9px;font-family:‘Karla’,sans-serif;font-size:0.78rem;color:var(–text);outline:none;width:85px;}
.hcp-row input:focus{border-color:var(–green-dim);}
.hcp-row button{background:var(–green);border:none;color:#0e0f0d;padding:5px 12px;border-radius:5px;font-family:‘Barlow Condensed’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;}
.hcp-row-lbl{font-size:0.7rem;color:var(–text-mid);}
.comp-bars{display:flex;flex-direction:column;gap:5px;}
.comp-row{display:flex;align-items:center;gap:9px;}
.comp-lbl{font-size:0.68rem;color:var(–text-mid);min-width:88px;text-align:right;}
.comp-track{flex:1;height:5px;background:var(–border);border-radius:3px;overflow:hidden;}
.comp-fill{height:100%;border-radius:3px;transition:width .4s;}
.comp-pct{font-family:‘Barlow Condensed’,sans-serif;font-size:0.7rem;font-weight:700;color:var(–text-mid);min-width:28px;}
.no-data{font-size:0.74rem;color:var(–text-dim);font-style:italic;text-align:center;padding:18px 0;}

/* ── MUSCLE HEATMAP ── */
.muscle-heat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(100px,1fr));gap:6px;}
.mh-cell{background:var(–surface2);border:1px solid var(–border);border-radius:7px;padding:10px 8px;text-align:center;}
.mh-name{font-family:‘Barlow Condensed’,sans-serif;font-size:0.72rem;font-weight:700;letter-spacing:1px;text-transform:uppercase;color:var(–text-mid);margin-bottom:4px;}
.mh-count{font-family:‘Barlow Condensed’,sans-serif;font-size:1.6rem;font-weight:900;line-height:1;}
.mh-sub{font-size:0.58rem;color:var(–text-dim);margin-top:1px;}

/* ── WEAKNESSES TAB ── */
.weak-card{background:var(–surface);border:1px solid var(–border);border-radius:9px;padding:14px 16px;margin-bottom:8px;display:flex;align-items:flex-start;gap:12px;}
.weak-rank{font-family:‘Barlow Condensed’,sans-serif;font-size:2rem;font-weight:900;line-height:1;min-width:32px;text-align:center;}
.weak-rank.r1{color:var(–red);}
.weak-rank.r2{color:var(–amber);}
.weak-rank.r3{color:var(–amber);opacity:0.7;}
.weak-rank.r4{color:var(–text-mid);}
.weak-rank.r5{color:var(–text-dim);}
.weak-body{flex:1;}
.weak-title{font-size:0.82rem;font-weight:700;color:var(–white);margin-bottom:3px;}
.weak-stat{font-family:‘Barlow Condensed’,sans-serif;font-size:1.1rem;font-weight:800;margin-bottom:4px;}
.weak-desc{font-size:0.7rem;color:var(–text-mid);line-height:1.5;}
.weak-target{display:inline-block;font-size:0.62rem;font-weight:600;letter-spacing:0.8px;text-transform:uppercase;background:var(–surface2);border:1px solid var(–border2);border-radius:4px;padding:2px 7px;margin-top:5px;color:var(–text-dim);}
.weak-bar-track{height:4px;background:var(–border);border-radius:2px;margin-top:8px;overflow:hidden;}
.weak-bar-fill{height:100%;border-radius:2px;}
.no-rounds-msg{text-align:center;padding:40px 20px;}
.no-rounds-msg h3{font-family:‘Barlow Condensed’,sans-serif;font-size:1.1rem;font-weight:800;letter-spacing:1px;color:var(–text-mid);margin-bottom:8px;}
.no-rounds-msg p{font-size:0.74rem;color:var(–text-dim);line-height:1.6;}

/* ── LOADING OVERLAY ── */
#loading-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;display:none;align-items:center;justify-content:center;flex-direction:column;gap:12px;}
.loading-spinner{width:32px;height:32px;border:3px solid var(–border2);border-top-color:var(–green);border-radius:50%;animation:spin .7s linear infinite;}
@keyframes spin{to{transform:rotate(360deg);}}
#loading-msg{font-family:‘Barlow Condensed’,sans-serif;font-size:0.85rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(–text-mid);}
.sync-dot{width:7px;height:7px;border-radius:50%;background:var(–text-dim);flex-shrink:0;transition:background .3s;}

/* ── FLEX BADGE ── */
.flex-badge{display:inline-block;background:var(–amber);color:#1a1000;font-size:0.55rem;font-weight:700;text-transform:uppercase;letter-spacing:0.8px;padding:2px 5px;border-radius:3px;margin-left:5px;vertical-align:middle;position:relative;top:-1px;}
</style>

</head>
<body>

<div class="topbar">
  <div class="logo">CJ <em>Tracker</em></div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="switchView('week',this)">Week</button>
    <button class="nav-tab" onclick="switchView('rounds',this)">Rounds</button>
    <button class="nav-tab" onclick="switchView('dashboard',this)">Dashboard</button>
    <button class="nav-tab" onclick="switchView('weaknesses',this)">Weaknesses</button>
  </div>
  <div id="sync-dot" class="sync-dot" title="Sync status"></div><div class="deadline-pill">Aug 14 — <span id="wks-left">—</span> wks</div>
</div>

<div class="main">

<!-- ══════ WEEK VIEW ══════ -->

<div id="view-week" class="view active">
  <div class="week-nav">
    <button class="wnav-btn" onclick="changeWeek(-1)">← Prev</button>
    <div>
      <div class="week-title" id="wk-title">Week 1</div>
      <div class="week-sub" id="wk-dates">—</div>
    </div>
    <button class="wnav-btn" onclick="changeWeek(1)">Next →</button>
  </div>
  <div class="prog-bar"><div class="prog-fill" id="prog-fill" style="width:0%"></div></div>
  <div class="week-type-row">
    <span class="wt-label">Week type:</span>
    <button class="wt-btn active" onclick="setWeekType('regular',this)">Regular</button>
    <button class="wt-btn amber" onclick="setWeekType('thu-travel',this)">Travel (Thu)</button>
    <button class="wt-btn blue" onclick="setWeekType('fri-travel',this)">Travel (Fri)</button>
  </div>
  <div class="scroll" id="week-body"></div>
</div>

<!-- ══════ ROUNDS VIEW ══════ -->

<div id="view-rounds" class="view">
