async function renderWeaknesses(){
const c=document.getElementById(‘weak-body’);
c.innerHTML=’<div class="no-data" style="padding-top:30px">Loading…</div>’;
const rounds=await loadRounds();
c.innerHTML=’’;

if(rounds.length<2){
c.innerHTML=`<div class="no-rounds-msg"><h3>Not Enough Data Yet</h3><p>Log at least 2 rounds to see your weakness analysis.</p></div>`;
return;
}

const statVals={putts:[],gir:[],fairways:[],updown:[],penalty:[]};
rounds.forEach(r=>{
if(r.stats){ Object.entries(r.stats).forEach(([k,v])=>{ if(statVals[k]) statVals[k].push(parseFloat(v)); }); }
else if(r.focusStat&&r.statVal&&statVals[r.focusStat]) statVals[r.focusStat].push(parseFloat(r.statVal));
});

const avg=arr=>arr.length>0?+(arr.reduce((a,b)=>a+b,0)/arr.length).toFixed(1):null;
const items=[];

const pAvg=avg(statVals.putts);
if(pAvg!==null){ const sev=Math.min(100,Math.max(0,((pAvg-28)/12)*100));
items.push({stat:‘Putting’,value:pAvg+’ putts/round’,desc:`Averaging ${pAvg} putts per round. A 14 HCP typically averages 32–34. Your Mon/Fri sessions target this directly.`,target:‘Goal: ≤33 putts per round’,severity:sev,color:’#9b7dd4’}); }

const gAvg=avg(statVals.gir);
if(gAvg!==null){ const sev=Math.min(100,Math.max(0,((9-gAvg)/9)*100));
items.push({stat:‘Greens in Regulation’,value:gAvg+’ GIR/round’,desc:`Hitting ${gAvg} greens per round. A 14 HCP typically hits 5–7 GIR. More GIR = more par/birdie chances.`,target:‘Goal: 6+ GIR per round’,severity:sev,color:’#5b8fd4’}); }

const fAvg=avg(statVals.fairways);
if(fAvg!==null){ const sev=Math.min(100,Math.max(0,((10-fAvg)/10)*100));
items.push({stat:‘Fairways Hit’,value:fAvg+’ fairways/round’,desc:`Hitting ${fAvg} fairways per round. Your Wed/Thu driver work directly targets this.`,target:‘Goal: 7+ fairways per round’,severity:sev,color:’#d4962a’}); }

const uAvg=avg(statVals.updown);
if(uAvg!==null){ const sev=Math.min(100,Math.max(0,((50-uAvg)/50)*100));
items.push({stat:‘Up-&-Down %’,value:uAvg+’%’,desc:`Converting ${uAvg}% of up-&-down attempts. A 14 HCP converts 30–40%. Your Monday chipping work targets this.`,target:‘Goal: 35%+ conversion’,severity:sev,color:’#4ab8a8’}); }

const penAvg=avg(statVals.penalty);
if(penAvg!==null){ const sev=Math.min(100,Math.max(0,(penAvg/4)*100));
items.push({stat:‘Penalty Strokes’,value:penAvg+’ per round’,desc:`Averaging ${penAvg} penalty strokes. Straighter driving and course management reduce this.`,target:‘Goal: <1 penalty per round’,severity:sev,color:’#d45b5b’}); }

if(!items.length){
c.innerHTML=’<div class="no-rounds-msg"><h3>Keep Logging Stats</h3><p>Add putts, GIR, fairways, or up-&-down data when logging rounds to see your breakdown.</p></div>’;
return;
}

items.sort((a,b)=>b.severity-a.severity);
const rankCls=[‘r1’,‘r2’,‘r3’,‘r4’,‘r5’];

const hdr=document.createElement(‘div’); hdr.style.cssText=‘padding:14px 0 10px;’;
hdr.innerHTML=`<div class="dash-sec" style="margin:0 0 4px">Your Biggest Weaknesses</div> <div style="font-size:0.72rem;color:var(--text-dim);line-height:1.6">Based on ${rounds.length} rounds. Fix in order — #1 is where strokes are bleeding most.</div>`;
c.appendChild(hdr);

items.forEach((item,i)=>{
const card=document.createElement(‘div’); card.className=‘weak-card’;
card.innerHTML=` <div class="weak-rank ${rankCls[i]||'r5'}">${i+1}</div> <div class="weak-body"> <div class="weak-title">${item.stat}</div> <div class="weak-stat" style="color:${item.color}">${item.value}</div> <div class="weak-desc">${item.desc}</div> <div class="weak-target">${item.target}</div> <div class="weak-bar-track"><div class="weak-bar-fill" style="width:${item.severity}%;background:${item.color}"></div></div> </div>`;
c.appendChild(card);
});

const note=document.createElement(‘div’);
note.style.cssText=‘font-size:0.7rem;color:var(–text-dim);text-align:center;padding:10px 0 4px;line-height:1.6;’;
note.textContent=‘Rankings update as you log more rounds. Log 5+ for reliable data.’;
c.appendChild(note);
}

// ═══════════════════════════════════════
// INIT
// ═══════════════════════════════════════
renderWeekView();
renderRoundsView();
</script>

