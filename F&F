async function loadWeekMeta(offset){
const key=getWK(offset);
if(cache.weekMeta[key]) return cache.weekMeta[key];
const {data}=await sb.from(‘week_meta’).select(’*’).eq(‘user_id’,UID).eq(‘week_key’,key).maybeSingle();
const meta=data||{week_key:key,week_type:‘regular’,custom_sessions:{}};
cache.weekMeta[key]=meta;
return meta;
}

async function saveWeekType(offset,type){
const key=getWK(offset);
const existing=await loadWeekMeta(offset);
const row={user_id:UID,week_key:key,week_type:type,custom_sessions:existing.custom_sessions||{}};
const {error}=await sb.from(‘week_meta’).upsert(row,{onConflict:‘week_key’});
showSync(!error);
cache.weekMeta[key]={…existing,…row};
}

async function saveCustomSession(offset,sid,customData){
const key=getWK(offset);
const existing=await loadWeekMeta(offset);
const cs={…(existing.custom_sessions||{}), [sid]:customData};
const row={user_id:UID,week_key:key,week_type:existing.week_type||‘regular’,custom_sessions:cs};
const {error}=await sb.from(‘week_meta’).upsert(row,{onConflict:‘week_key’});
showSync(!error);
cache.weekMeta[key]={…existing,…row,custom_sessions:cs};
}

